generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IndividualRegistration {
  id                     String   @id @default(cuid())
  registrationId         String   @unique
  fullName               String
  age                    String
  institution            String
  email                  String
  phone                  String
  committeePreference1   String
  committeePreference2   String?
  committeePreference3   String?
  portfolioPreference1   String
  portfolioPreference2   String?
  portfolioPreference3   String?
  accommodationRequired  Boolean  @default(false)
  accommodationScheme    String?
  transactionId          String
  totalAmount            Int
  status                 String   @default("pending")
  createdAt              DateTime @default(now())
}

model DelegationRegistration {
  id                     String   @id @default(cuid())
  registrationId         String   @unique
  institution            String
  city                   String?
  headDelegateName       String
  headDelegateEmail      String
  headDelegatePhone      String
  numberOfDelegates      String
  accommodationRequired  Boolean  @default(false)
  accommodationDelegates String?
  accommodationScheme    String?
  perHeadPrice           Int
  totalAmount            Int
  transactionId          String
  status                 String   @default("pending")
  createdAt              DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
